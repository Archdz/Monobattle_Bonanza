//--------------------------------------------------------------------------------------------------
// Trigger: Losowanie
//--------------------------------------------------------------------------------------------------
bool lib32AF1ADC_gt_Losowanie_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    playergroup auto6BE4D78E_g;
    int auto6BE4D78E_var;

    // Actions
    if (!runActions) {
        return true;
    }

    auto6BE4D78E_g = PlayerGroupAll();
    auto6BE4D78E_var = -1;
    while (true) {
        auto6BE4D78E_var = PlayerGroupNextPlayer(auto6BE4D78E_g, auto6BE4D78E_var);
        if (auto6BE4D78E_var < 0) { break; }
        lib32AF1ADC_gv_rzut = RandomInt(0, 15);
        libNtve_gf_SetUpgradeLevelForPlayer(auto6BE4D78E_var, lib32AF1ADC_gv_terranPool[lib32AF1ADC_gv_rzut], 1);
        UIDisplayMessage(PlayerGroupAll(), c_messageAreaSubtitle, (StringExternal("Param/Value/lib_32AF1ADC_6CB03CC1") + IntToText(lib32AF1ADC_gv_rzut)));
    }
    return true;
}

//--------------------------------------------------------------------------------------------------
void lib32AF1ADC_gt_Losowanie_Init () {
    lib32AF1ADC_gt_Losowanie = TriggerCreate("lib32AF1ADC_gt_Losowanie_Func");
    TriggerAddEventMapInit(lib32AF1ADC_gt_Losowanie);
}

void lib32AF1ADC_InitTriggers () {
    lib32AF1ADC_gt_UntitledTrigger001_Init();
    lib32AF1ADC_gt_Inicjalizacja_Init();
    lib32AF1ADC_gt_Losowanie_Init();
}

//--------------------------------------------------------------------------------------------------
// Library Initialization
//--------------------------------------------------------------------------------------------------
bool lib32AF1ADC_InitLib_completed = false;

void lib32AF1ADC_InitLib () {
    if (lib32AF1ADC_InitLib_completed) {
        return;
    }

    lib32AF1ADC_InitLib_completed = true;

    lib32AF1ADC_InitLibraries();
    lib32AF1ADC_InitVariables();
    lib32AF1ADC_InitCustomScript();
    lib32AF1ADC_InitTriggers();
}

