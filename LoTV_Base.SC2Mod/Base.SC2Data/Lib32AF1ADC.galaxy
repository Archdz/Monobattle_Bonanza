    lib32AF1ADC_gv_terranPool[7] = "PriviligeCyclone";
    lib32AF1ADC_gv_terranPool[8] = "PriviligeSiegeTank";
    lib32AF1ADC_gv_terranPool[9] = "PriviligeThor";
    lib32AF1ADC_gv_terranPool[10] = "PriviligeViking";
    lib32AF1ADC_gv_terranPool[11] = "PriviligeMedivac";
    lib32AF1ADC_gv_terranPool[12] = "PriviligeLiberator";
    lib32AF1ADC_gv_terranPool[13] = "PriviligeRaven";
