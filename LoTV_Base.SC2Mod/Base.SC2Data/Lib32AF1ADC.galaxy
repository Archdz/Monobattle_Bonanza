include "TriggerLibs/NativeLib"

include "Lib32AF1ADC_h"

//--------------------------------------------------------------------------------------------------
// Library: Library
//--------------------------------------------------------------------------------------------------
// External Library Initialization
void lib32AF1ADC_InitLibraries () {
    libNtve_InitVariables();
}

// Custom Script
//--------------------------------------------------------------------------------------------------
// Custom Script: Bootstrap
//--------------------------------------------------------------------------------------------------
include "scripts/main"

void lib32AF1ADC_InitCustomScript () {
    main();
}

// Triggers
//--------------------------------------------------------------------------------------------------
// Trigger: Untitled Trigger 002
//--------------------------------------------------------------------------------------------------
bool lib32AF1ADC_gt_Testing_cheats_Func (bool testConds, bool runActions) {
    // Automatic Variable Declarations
    playergroup autoCBC77FD5_g;
    int autoCBC77FD5_var;

    // Actions
    if (!runActions) {
        return true;
    }

    autoCBC77FD5_g = PlayerGroupAll();
    autoCBC77FD5_var = -1;
    while (true) {
        autoCBC77FD5_var = PlayerGroupNextPlayer(autoCBC77FD5_g, autoCBC77FD5_var);
        if (autoCBC77FD5_var < 0) { break; }
        Wait(1.0, c_timeReal);
        PlayerModifyPropertyInt(autoCBC77FD5_var, c_playerPropMinerals, c_playerPropOperAdd, 5000);
        PlayerModifyPropertyInt(autoCBC77FD5_var, c_playerPropVespene, c_playerPropOperAdd, 5000);
    }
    return true;
}

//--------------------------------------------------------------------------------------------------
void lib32AF1ADC_gt_Testing_cheats_Init () {
    lib32AF1ADC_gt_Testing_cheats = TriggerCreate("lib32AF1ADC_gt_Testing_cheats_Func");
    TriggerAddEventMapInit(lib32AF1ADC_gt_Testing_cheats);
}

void lib32AF1ADC_InitTriggers () {
    lib32AF1ADC_gt_Testing_cheats_Init();
}

//--------------------------------------------------------------------------------------------------
// Library Initialization
//--------------------------------------------------------------------------------------------------
bool lib32AF1ADC_InitLib_completed = false;

void lib32AF1ADC_InitLib () {
    if (lib32AF1ADC_InitLib_completed) {
        return;
    }

    lib32AF1ADC_InitLib_completed = true;

    lib32AF1ADC_InitLibraries();
    lib32AF1ADC_InitCustomScript();
    lib32AF1ADC_InitTriggers();
}

